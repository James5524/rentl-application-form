# Copy this file to .env and fill in your own values.
# Everything here is optional for local use - the app works fine without it,
# using a local data/db.json file. These matter mainly when deployed (e.g. Render).

# Persistent storage (recommended once deployed - see README). Without these,
# stored forms/submissions are lost whenever the host restarts. Get both free
# values from https://upstash.com after creating a free Redis database - look
# for the "REST API" section on your database's page.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Email notifications: get a copy of every form submission by email.
# Get a free API key at https://resend.com after signing up.
RESEND_API_KEY=

# The address that should receive a copy of every submission.
NOTIFY_EMAIL=office@jgla.co.uk

# Optional: only change this once you've verified your own domain in Resend.
# Until then, the default resend.dev address works fine for sending to yourself.
# NOTIFY_FROM=FormForge <onboarding@resend.dev>
