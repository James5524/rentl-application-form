# Copy this file to .env and fill in your own values to get an email
# copy of every form submission. Leave blank/omit to disable emails.

# Get a free API key at https://resend.com after signing up.
RESEND_API_KEY=

# The address that should receive a copy of every submission.
NOTIFY_EMAIL=office@jgla.co.uk

# Optional: only change this once you've verified your own domain in Resend.
# Until then, the default resend.dev address works fine for sending to yourself.
# NOTIFY_FROM=FormForge <onboarding@resend.dev>
